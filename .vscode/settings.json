{
  // в”Ђв”Ђв”Ђ Activation layer for the brain-core harness в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  // Pins how VS Code + GitHub Copilot discover and load the harness, so EVERY
  // teammate loads it deterministically regardless of their personal settings or
  // their VS Code/Copilot version defaults. Current defaults already point at
  // .github/{instructions,prompts,agents,skills}; this file guarantees it does
  // not depend on those defaults staying put across versions or user overrides.
  //
  // This is NOT the excluded .vscode/mcp.json вЂ” MCP config stays deliberately
  // unbuilt (blueprint В§15). See SETUP.md for how to confirm the harness loaded.

  // в”Ђв”Ђ Principles: .github/copilot-instructions.md + .github/instructions/*.instructions.md в”Ђв”Ђ
  // Auto-loads the root copilot-instructions.md into chat requests.
  "github.copilot.chat.codeGeneration.useInstructionFiles": true,
  // Auto-loads any .instructions.md whose applyTo pattern matches (ours are "**").
  "chat.includeApplyingInstructions": true,
  // Where to discover .instructions.md files.
  "chat.instructionsFilesLocations": { ".github/instructions": true },

  // в”Ђв”Ђ Prompts: .github/prompts/*.prompt.md (invoked with /name) в”Ђв”Ђ
  "chat.promptFilesLocations": { ".github/prompts": true },

  // в”Ђв”Ђ Agents: .github/agents/*.agent.md в”Ђв”Ђ
  "chat.agentFilesLocations": { ".github/agents": true },

  // в”Ђв”Ђ Skills: .github/skills/<name>/SKILL.md (progressive discovery) в”Ђв”Ђ
  "chat.agentSkillsLocations": { ".github/skills": true },
  // Enable-gate for skills. Introduced opt-in in VS Code 1.108 (per its release notes);
  // enabled by default in later stable releases. Pinned so skills work on 1.108-era versions
  // where it was opt-in, and harmlessly redundant where already default-on вЂ” consistent with
  // this file's pinning rationale.
  "chat.useAgentSkills": true

  // Version note (verified against VS Code release notes, 2026-07): agent files
  // (`chat.agentFilesLocations`, `.agent.md`) ~v1.106; agent skills
  // (`chat.agentSkillsLocations`, `chat.useAgentSkills`, `.github/skills`) v1.108, default-on
  // in later stable. Binding minimum в‰Ґ 1.108 вЂ” see SETUP.md В§1. Confirm keys against the
  // installed version (Settings UI в†’ search each key) if anything fails to load.
  // Open question (blueprint В§6, still unverified): whether applyTo:"**" in a separate file
  // behaves identically to inlining into copilot-instructions.md in a purely conversational
  // request (no file open); `chat.includeApplyingInstructions` above is the lever to test it.
}
