{
  "inputs": [
    {
      "id": "sf_read_org",
      "type": "promptString",
      "description": "Allowlisted non-production Salesforce alias for read-only investigation"
    }
  ],
  "servers": {
    "ado-readonly": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@azure-devops/mcp@2.8.1",
        "${env:ADO_ORGANIZATION}",
        "-d",
        "work-items",
        "wiki",
        "test-plans",
        "search"
      ]
    },
    "salesforce-readonly": {
      "type": "stdio",
      "command": "node",
      "cwd": "${workspaceFolder}",
      "args": [
        "scripts/start_salesforce_mcp.mjs",
        "--mode",
        "review",
        "--org",
        "${input:sf_read_org}"
      ]
    }
  }
}
