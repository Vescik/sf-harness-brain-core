<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Margin_Percent__c</fullName>
    <description>Gross margin percent derived from bill and cost rates. Formula field.</description>
    <externalId>false</externalId>
    <formula>IF(OR(ISBLANK(Bill_Rate__c), Bill_Rate__c = 0), null, (Bill_Rate__c - BLANKVALUE(Cost_Rate__c, 0)) / Bill_Rate__c * 100)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Margin Percent</label>
    <precision>18</precision>
    <required>false</required>
    <scale>1</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Number</type>
    <unique>false</unique>
</CustomField>
