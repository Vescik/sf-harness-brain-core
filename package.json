{
  "name": "sf-harness-brain-core",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "description": "Single-root Salesforce DX project and governed GitHub Copilot harness.",
  "scripts": {
    "lint": "eslint --no-error-on-unmatched-pattern \"force-app/main/default/{aura,lwc}/**/*.js\"",
    "test": "npm run test:unit",
    "test:unit": "sfdx-lwc-jest",
    "test:unit:watch": "sfdx-lwc-jest --watch",
    "test:unit:debug": "sfdx-lwc-jest --debug",
    "test:unit:coverage": "sfdx-lwc-jest --coverage",
    "test:unit:ci": "sfdx-lwc-jest -- --passWithNoTests",
    "prettier": "prettier --write --no-error-on-unmatched-pattern \"force-app/**/*.{cls,cmp,component,css,html,js,json,md,page,trigger,xml,yaml,yml}\" \"manifest/**/*.xml\" \"sfdx-project.json\" \"config/project-scratch-def.json\"",
    "prettier:verify": "prettier --check --no-error-on-unmatched-pattern \"force-app/**/*.{cls,cmp,component,css,html,js,json,md,page,trigger,xml,yaml,yml}\" \"manifest/**/*.xml\" \"sfdx-project.json\" \"config/project-scratch-def.json\""
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@salesforce/mcp": "0.30.15"
  },
  "overrides": {
    "@babel/core": "^7.29.6",
    "protobufjs": "^7.6.3",
    "postcss": "^8.5.10",
    "fast-uri": "^3.1.4",
    "fast-xml-parser@^5.0.0": "^5.10.1",
    "@hono/node-server": "^2.0.5"
  },
  "devDependencies": {
    "@emnapi/core": "1.11.2",
    "@emnapi/runtime": "1.11.2",
    "@eslint/js": "^9.29.0",
    "@lwc/eslint-plugin-lwc": "^3.1.0",
    "@prettier/plugin-xml": "^3.4.1",
    "@salesforce/eslint-config-lwc": "^4.0.0",
    "@salesforce/eslint-plugin-aura": "^3.0.0",
    "@salesforce/eslint-plugin-lightning": "^2.0.0",
    "@salesforce/sfdx-lwc-jest": "^7.0.2",
    "eslint": "^9.39.5",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jest": "^28.14.0",
    "globals": "^15.14.0",
    "prettier": "^3.9.6",
    "prettier-plugin-apex": "^2.2.6"
  }
}
