{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:sf-harness-brain-core:knowledge-claims-index.schema.json",
  "title": "Generated machine-readable Knowledge claims index",
  "description": "Deterministic search surface rendered by knowledge_registry.py render-indexes alongside the domain Markdown views. Generated from canonical claims only — never hand-edited, never a source of truth, and only rows with effective: true are established facts.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "kind", "claimCount", "claims"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "kind": { "const": "knowledge-claims-index" },
    "claimCount": { "type": "integer", "minimum": 0 },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claimId", "revision", "domain", "claimType", "subject", "predicate", "status",
          "effective", "reviewBy", "keywords", "candidateKeywords", "statement",
          "evidenceRefs", "path"
        ],
        "properties": {
          "claimId": { "type": "string", "pattern": "^KCLM-[A-Z0-9][A-Z0-9-]{2,79}$" },
          "revision": { "type": "integer", "minimum": 1 },
          "domain": { "type": "string", "minLength": 1 },
          "claimType": { "type": "string", "minLength": 1 },
          "subject": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "identity"],
            "properties": {
              "kind": { "type": "string", "minLength": 1 },
              "identity": { "type": "string", "minLength": 1 }
            }
          },
          "predicate": { "type": "string", "minLength": 1 },
          "status": { "enum": ["proposed", "verified", "stale", "contested", "superseded", "rejected"] },
          "effective": { "type": "boolean" },
          "reviewBy": { "type": "string", "format": "date-time" },
          "keywords": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
          "candidateKeywords": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
          "feature": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1, "maxLength": 80 } },
          "usesObjects": { "description": "Objects the claim's subject uses, derived from its component usage registry.", "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
          "usesFields": { "description": "Object.Field references the claim's subject uses, derived from its component usage registry.", "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
          "statement": { "type": "string", "minLength": 1 },
          "descriptionExcerpt": { "type": "string", "minLength": 1, "maxLength": 240 },
          "evidenceRefs": {
            "type": "array", "uniqueItems": true,
            "items": { "type": "string", "pattern": "^KEVD-[A-Z0-9][A-Z0-9-]{2,79}$" }
          },
          "path": { "type": "string", "pattern": "^\\.ai/knowledge/claims/" }
        }
      }
    }
  }
}
