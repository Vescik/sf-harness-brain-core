{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sf-harness-brain-core/schemas/knowledge-profile-validationrule.schema.json",
  "title": "Knowledge Entry profile \u2014 salesforce.validation-rule v1",
  "description": "typeFacts carry the collector's extraction faithfully: an adapter passes every fact through except a documented exclusion, so a fact the profile does not declare fails validation loudly instead of vanishing from the entry.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "typeFacts"
  ],
  "properties": {
    "typeFacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object"
      ],
      "properties": {
        "object": {
          "type": "string"
        },
        "active": {
          "type": "boolean"
        },
        "errorDisplayField": {
          "type": "string"
        },
        "errorCatalog": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "component": {
                "type": "string"
              },
              "kind": {
                "type": "string"
              },
              "errorMessage": {
                "type": "string"
              },
              "condition": {
                "type": "string"
              },
              "fieldSelection": {
                "type": "string"
              },
              "resolvedErrorMessage": {
                "type": "string"
              }
            }
          },
          "description": "The rule itself: author-declared error message, the condition formula that raises it, and the field it is displayed on. Carried verbatim so an entry answers what the rule enforces, not merely that it has one."
        },
        "references": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "target",
              "assurance"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "pattern": "^[a-z][a-z-]{2,40}$"
              },
              "target": {
                "type": "string",
                "minLength": 1
              },
              "assurance": {
                "enum": [
                  "source-exact",
                  "source-derived-heuristic"
                ]
              }
            }
          }
        },
        "errorMessagePresent": {
          "type": "boolean"
        }
      }
    },
    "intentionalErrors": {
      "type": "array",
      "maxItems": 0
    }
  }
}
