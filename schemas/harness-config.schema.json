{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Vescik/sf-harness-brain-core/schemas/harness-config.schema.json",
  "title": "Brain-core local configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "ado", "salesforce", "safety", "browser", "workspace", "cache"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "ado": {
      "type": "object",
      "additionalProperties": false,
      "required": ["organization", "project", "releaseQueryId", "allowedHttpsOrigins"],
      "properties": {
        "organization": { "type": "string", "minLength": 1 },
        "project": { "type": "string", "minLength": 1 },
        "releaseQueryId": { "type": "string", "minLength": 1 },
        "allowedHttpsOrigins": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^https://" }
        }
      }
    },
    "salesforce": {
      "type": "object",
      "additionalProperties": false,
      "required": ["orgs", "review"],
      "properties": {
        "orgs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "alias",
              "environment",
              "allowAgentRead",
              "allowAgentWrite",
              "allowAgentReview",
              "expectedInstanceHost",
              "expectedOrganizationId"
            ],
            "properties": {
              "alias": {
                "type": "string",
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,79}$"
              },
              "environment": { "enum": ["development", "qa", "uat"] },
              "allowAgentRead": { "type": "boolean" },
              "allowAgentWrite": { "type": "boolean" },
              "allowAgentReview": { "type": "boolean" },
              "expectedInstanceHost": {
                "type": "string",
                "pattern": "^[A-Za-z0-9][A-Za-z0-9-]*--[A-Za-z0-9][A-Za-z0-9-]*\\.sandbox\\.my\\.salesforce\\.com$"
              },
              "expectedOrganizationId": {
                "type": "string",
                "pattern": "^00D[A-Za-z0-9]{12}(?:[A-Za-z0-9]{3})?$"
              }
            },
            "allOf": [
              {
                "if": {
                  "properties": { "allowAgentReview": { "const": true } },
                  "required": ["allowAgentReview"]
                },
                "then": {
                  "properties": { "allowAgentRead": { "const": true } }
                }
              }
            ]
          }
        },
        "review": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "enabled",
            "apiVersion",
            "requireDualSource",
            "allowedPackageNamespaces",
            "allowedObjectApiNames",
            "maxObjectsPerCall",
            "maxFieldsPerObject",
            "evidenceMaxAgeMinutes"
          ],
          "properties": {
            "enabled": { "type": "boolean" },
            "apiVersion": { "type": "string", "pattern": "^[0-9]{2}\\.0$" },
            "requireDualSource": { "const": true },
            "allowedPackageNamespaces": {
              "type": "array",
              "maxItems": 20,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "pattern": "^[A-Za-z][A-Za-z0-9]{0,14}$"
              }
            },
            "allowedObjectApiNames": {
              "type": "array",
              "maxItems": 100,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "pattern": "^[A-Za-z][A-Za-z0-9_]{0,79}$"
              }
            },
            "maxObjectsPerCall": { "type": "integer", "minimum": 1, "maximum": 10 },
            "maxFieldsPerObject": { "type": "integer", "minimum": 1, "maximum": 500 },
            "evidenceMaxAgeMinutes": { "type": "integer", "minimum": 1, "maximum": 30 }
          },
          "allOf": [
            {
              "if": {
                "properties": { "enabled": { "const": true } },
                "required": ["enabled"]
              },
              "then": {
                "properties": {
                  "allowedPackageNamespaces": { "minItems": 1 },
                  "allowedObjectApiNames": { "minItems": 1 }
                }
              },
              "else": {
                "properties": {
                  "allowedPackageNamespaces": { "maxItems": 0 },
                  "allowedObjectApiNames": { "maxItems": 0 }
                }
              }
            }
          ]
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sharedSandboxWritesApproved", "sharedSandboxApprovalRef"],
      "properties": {
        "sharedSandboxWritesApproved": { "type": "boolean" },
        "sharedSandboxApprovalRef": { "type": "string" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "sharedSandboxWritesApproved": { "const": true } },
            "required": ["sharedSandboxWritesApproved"]
          },
          "then": {
            "properties": { "sharedSandboxApprovalRef": { "minLength": 1 } }
          }
        }
      ]
    },
    "browser": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowedOrigins", "profileDirectory"],
      "properties": {
        "allowedOrigins": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^https://[A-Za-z0-9-]+--[A-Za-z0-9-]+\\.sandbox\\.(my\\.salesforce\\.com|lightning\\.force\\.com|my\\.site\\.com)/?$"
          }
        },
        "profileDirectory": { "type": "string", "minLength": 1 }
      }
    },
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["salesforceRootName", "manifestPath", "promotedTestsPath"],
      "properties": {
        "salesforceRootName": { "const": "brain-core" },
        "manifestPath": { "type": "string", "minLength": 1 },
        "promotedTestsPath": { "type": "string", "minLength": 1 }
      }
    },
    "cache": {
      "type": "object",
      "additionalProperties": false,
      "required": ["adoItemMaxAgeMinutes", "testCaseMaxAgeMinutes", "onStaleDefault"],
      "properties": {
        "adoItemMaxAgeMinutes": { "type": "integer", "minimum": 1 },
        "testCaseMaxAgeMinutes": { "type": "integer", "minimum": 1 },
        "onStaleDefault": { "enum": ["ask", "refresh", "use", "fail"] }
      }
    }
  }
}
