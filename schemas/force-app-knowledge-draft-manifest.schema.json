{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:sf-harness-brain-core:force-app-knowledge-draft-manifest.schema.json",
  "title": "force-app Knowledge proposal draft manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion", "kind", "generatedAt", "repositoryCommit", "sourceTreeDigest",
    "reviewStatus", "claimCount", "bundles", "limitations"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "kind": { "const": "force-app-knowledge-draft-manifest" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "repositoryCommit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "sourceTreeDigest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "reviewStatus": { "const": "draft" },
    "claimCount": { "type": "integer", "minimum": 0 },
    "bundles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claimId", "disposition"],
        "properties": {
          "claimId": { "type": "string", "pattern": "^KCLM-[A-Z0-9][A-Z0-9-]{2,79}$" },
          "evidenceId": { "type": "string", "pattern": "^KEVD-[A-Z0-9][A-Z0-9-]{2,79}$" },
          "claimFile": { "type": "string", "pattern": "^\\.cache/knowledge-proposals/force-app-drafts/" },
          "evidenceFile": { "type": "string", "pattern": "^\\.cache/knowledge-proposals/force-app-drafts/" },
          "expectedRevision": { "type": "integer", "minimum": 0 },
          "disposition": { "enum": ["new", "update-proposed", "existing-non-proposed"] },
          "command": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 }
        },
        "allOf": [
          {
            "if": { "properties": { "disposition": { "enum": ["new", "update-proposed"] } } },
            "then": { "required": ["evidenceId", "claimFile", "evidenceFile", "expectedRevision", "command"] }
          },
          {
            "if": { "properties": { "disposition": { "const": "existing-non-proposed" } } },
            "then": { "required": ["reason"] }
          }
        ]
      }
    },
    "limitations": {
      "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }
    }
  }
}
