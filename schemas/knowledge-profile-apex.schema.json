{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sf-harness-brain-core/schemas/knowledge-profile-apex.schema.json",
  "title": "Knowledge Entry profile \u2014 salesforce.apex v1 (ApexClass, ApexTrigger)",
  "description": "typeFacts carry the collector's extraction faithfully: an adapter passes every fact through except a documented exclusion, so a fact the profile does not declare fails validation loudly instead of vanishing from the entry.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "typeFacts"
  ],
  "properties": {
    "typeFacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "enum": [
            "ApexClass",
            "ApexTrigger"
          ]
        },
        "declarationKind": {
          "type": "string"
        },
        "sharingModel": {
          "type": "string"
        },
        "isTest": {
          "type": "boolean"
        },
        "apiVersion": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "superclass": {
          "type": "string"
        },
        "interfaces": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "annotations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "object": {
          "type": "string"
        },
        "events": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "soqlObjects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dmlOperations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dmlTargets": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "description": "Per-object DML verbs observed in source (heuristic token scan)."
        },
        "references": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "target",
              "assurance"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "pattern": "^[a-z][a-z-]{2,40}$"
              },
              "target": {
                "type": "string",
                "minLength": 1
              },
              "assurance": {
                "enum": [
                  "source-exact",
                  "source-derived-heuristic"
                ]
              }
            }
          }
        },
        "description": {
          "type": "string",
          "description": "The author's own statement of intent, taken verbatim from source (ApexDoc @description or the metadata <description> element)."
        }
      }
    },
    "intentionalErrors": {
      "type": "array",
      "maxItems": 0
    }
  }
}
