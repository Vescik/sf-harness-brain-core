{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:sf-harness-brain-core:force-app-relations-worklist.schema.json",
  "title": "force-app relation-claim edge worklist",
  "description": "Edge-granular status for every object-relation/component-relation candidate derived from the current inventory, diffed against canonical claims. Recomputed from ground truth on every invocation; never hand-edited and never authoritative on its own.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion", "kind", "generatedAt", "repositoryCommit", "sourceTreeDigest",
    "counts", "items"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "kind": { "const": "force-app-relations-worklist" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "repositoryCommit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "sourceTreeDigest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "metadataTypeFilter": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_]{0,79}$" },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "missing": { "type": "integer", "minimum": 0 },
        "proposed": { "type": "integer", "minimum": 0 },
        "verified-current": { "type": "integer", "minimum": 0 },
        "verified-stale": { "type": "integer", "minimum": 0 },
        "blocked": { "type": "integer", "minimum": 0 }
      }
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claimId", "claimType", "sourceComponentId", "sourceMetadataType", "predicate",
          "target", "heuristic", "state"
        ],
        "properties": {
          "claimId": { "type": "string", "pattern": "^KCLM-[A-Z0-9][A-Z0-9-]{2,79}$" },
          "claimType": { "enum": ["object-relation", "component-relation"] },
          "sourceComponentId": { "type": "string", "minLength": 1 },
          "sourceMetadataType": { "type": "string", "minLength": 1 },
          "predicate": { "type": "string", "minLength": 1 },
          "target": { "type": "string", "minLength": 1 },
          "heuristic": { "type": "boolean" },
          "state": {
            "enum": ["missing", "proposed", "verified-current", "verified-stale", "blocked"]
          },
          "revision": { "type": "integer", "minimum": 1 },
          "reason": { "type": "string", "minLength": 1 }
        },
        "allOf": [
          {
            "if": { "properties": { "state": { "const": "blocked" } } },
            "then": { "required": ["reason"] }
          }
        ]
      }
    }
  }
}
