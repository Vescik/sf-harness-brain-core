{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Vescik/sf-harness-brain-core/schemas/principle-registry.schema.json",
  "title": "Principle rule provenance registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "rules"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ruleId", "tier", "status", "sourceFile", "ownerRole", "basis", "scope", "review"],
        "properties": {
          "ruleId": { "type": "string", "pattern": "^(SAFE|MP|ORG|SF)-[A-Z0-9-]+$" },
          "tier": { "enum": ["kernel", "1", "2", "3"] },
          "status": { "enum": ["active", "provisional", "stale", "retired"] },
          "sourceFile": { "type": "string", "pattern": "^\\.github/(copilot-instructions\\.md|instructions/[a-z-]+\\.instructions\\.md)$" },
          "ownerRole": { "type": ["string", "null"], "minLength": 1 },
          "basis": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "completeness", "sourceRefs", "claimRefs"],
            "properties": {
              "kind": { "enum": ["repository-policy", "managed-package-policy", "organization-policy", "salesforce-platform-practice"] },
              "completeness": { "enum": ["complete", "partial"] },
              "sourceRefs": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
              "claimRefs": { "type": "array", "uniqueItems": true, "items": { "type": "string", "pattern": "^KCLM-[A-Z0-9][A-Z0-9-]{2,79}$" } }
            }
          },
          "scope": { "enum": ["global", "managed-package", "organization", "salesforce-platform"] },
          "packageScope": {
            "anyOf": [
              { "type": "null" },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["namespace", "packageKey", "version"],
                "properties": {
                  "namespace": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_]{0,14}$" },
                  "packageKey": { "type": ["string", "null"], "minLength": 1 },
                  "version": { "type": "string", "minLength": 1 }
                }
              }
            ]
          },
          "review": {
            "type": "object",
            "additionalProperties": false,
            "required": ["lastReviewedAt", "reviewBy"],
            "properties": {
              "lastReviewedAt": { "type": ["string", "null"], "format": "date-time" },
              "reviewBy": { "type": ["string", "null"], "format": "date-time" }
            }
          }
        },
        "allOf": [
          {
            "if": { "properties": { "tier": { "const": "kernel" } }, "required": ["tier"] },
            "then": { "properties": { "ruleId": { "pattern": "^SAFE-" } } }
          },
          {
            "if": { "properties": { "tier": { "const": "1" } }, "required": ["tier"] },
            "then": { "properties": { "ruleId": { "pattern": "^MP-" } } }
          },
          {
            "if": { "properties": { "tier": { "const": "2" } }, "required": ["tier"] },
            "then": { "properties": { "ruleId": { "pattern": "^ORG-" } } }
          },
          {
            "if": { "properties": { "tier": { "const": "3" } }, "required": ["tier"] },
            "then": { "properties": { "ruleId": { "pattern": "^SF-" } } }
          },
          {
            "if": { "properties": { "packageScope": { "type": "object" } }, "required": ["packageScope"] },
            "then": {
              "properties": {
                "tier": { "const": "1" },
                "scope": { "const": "managed-package" }
              }
            }
          }
        ]
      }
    }
  }
}
