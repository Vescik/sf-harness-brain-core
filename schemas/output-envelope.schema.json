{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:sf-harness-brain-core:output-envelope.schema.json",
  "title": "Generated artifact evidence envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "workflow",
    "workflowClass",
    "generatedAt",
    "status",
    "recordRef",
    "sourceRefs",
    "ruleRefs",
    "claimRefs",
    "evidenceRefs",
    "knowledgeSnapshotAt",
    "reconciliation",
    "completeness",
    "reviewStatus",
    "assumptions",
    "warnings",
    "filesWritten",
    "verification",
    "artifactPath"
  ],
  "properties": {
    "schemaVersion": { "const": 3 },
    "workflow": { "type": "string", "minLength": 1 },
    "workflowClass": { "enum": ["governed", "cache-read"] },
    "generatedAt": { "type": "string", "format": "date-time" },
    "status": { "enum": ["success", "incomplete", "failed"] },
    "recordRef": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/recordRef" }
      ]
    },
    "sourceRefs": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "ruleRefs": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^(SAFE|MP|ORG|SF)-[A-Z0-9-]+$" }
    },
    "claimRefs": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^KCLM-[A-Z0-9][A-Z0-9-]{2,79}$" }
    },
    "evidenceRefs": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^(KEVD|EV)-[A-Za-z0-9][A-Za-z0-9._-]{2,127}$" }
    },
    "knowledgeSnapshotAt": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "format": "date-time" }
      ]
    },
    "reconciliation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "mismatches", "missingEvidence"],
      "properties": {
        "status": { "enum": ["not-required", "matched", "source-org-drift", "contested", "incomplete"] },
        "mismatches": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "missingEvidence": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "completeness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "missingEvidence"],
      "properties": {
        "status": { "enum": ["complete", "partial"] },
        "missingEvidence": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "reviewStatus": { "enum": ["draft", "accepted", "rejected", "promoted"] },
    "assumptions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "filesWritten": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "verification": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "artifactPath": { "type": ["string", "null"] }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "handoffId": {
      "type": "string",
      "pattern": "^HO-[A-Za-z0-9][A-Za-z0-9._-]{5,127}$"
    },
    "recordRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recordId",
        "recordRevision",
        "recordHash",
        "scopeHash",
        "designHash",
        "groundingHash",
        "consumedHandoffId",
        "createdHandoffId"
      ],
      "properties": {
        "recordId": {
          "type": "string",
          "pattern": "^ADO-[a-z0-9][a-z0-9-]{0,62}-[1-9][0-9]*$"
        },
        "recordRevision": { "type": "integer", "minimum": 1 },
        "recordHash": { "$ref": "#/$defs/sha256" },
        "scopeHash": { "$ref": "#/$defs/sha256" },
        "designHash": { "$ref": "#/$defs/sha256" },
        "groundingHash": { "$ref": "#/$defs/sha256" },
        "consumedHandoffId": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/handoffId" }
          ]
        },
        "createdHandoffId": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/handoffId" }
          ]
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "status": { "const": "success" } },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "completeness": {
            "properties": {
              "status": { "const": "complete" },
              "missingEvidence": { "maxItems": 0 }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "workflowClass": { "const": "cache-read" } },
        "required": ["workflowClass"]
      },
      "then": {
        "properties": {
          "recordRef": { "type": "null" },
          "reviewStatus": { "enum": ["draft", "rejected"] }
        }
      }
    },
    {
      "if": {
        "anyOf": [
          {
            "properties": {
              "workflowClass": { "const": "governed" },
              "status": { "const": "success" }
            },
            "required": ["workflowClass", "status"]
          },
          {
            "properties": {
              "reviewStatus": { "enum": ["accepted", "promoted"] }
            },
            "required": ["reviewStatus"]
          }
        ]
      },
      "then": {
        "properties": {
          "workflowClass": { "const": "governed" },
          "status": { "const": "success" },
          "recordRef": {
            "type": "object",
            "anyOf": [
              {
                "properties": { "consumedHandoffId": { "$ref": "#/$defs/handoffId" } },
                "required": ["consumedHandoffId"]
              },
              {
                "properties": { "createdHandoffId": { "$ref": "#/$defs/handoffId" } },
                "required": ["createdHandoffId"]
              }
            ]
          },
          "sourceRefs": { "minItems": 1 },
          "ruleRefs": { "minItems": 1 },
          "claimRefs": { "minItems": 1 },
          "evidenceRefs": { "minItems": 1 },
          "knowledgeSnapshotAt": { "type": "string", "format": "date-time" },
          "reconciliation": {
            "properties": {
              "status": { "enum": ["not-required", "matched"] },
              "mismatches": { "maxItems": 0 },
              "missingEvidence": { "maxItems": 0 }
            }
          },
          "completeness": {
            "properties": {
              "status": { "const": "complete" },
              "missingEvidence": { "maxItems": 0 }
            }
          },
          "verification": { "minItems": 1 }
        }
      }
    }
  ]
}
