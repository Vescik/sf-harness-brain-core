{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sf-harness-brain-core/schemas/knowledge-profile-custommetadata.schema.json",
  "title": "Knowledge Entry profile \u2014 salesforce.custom-metadata v1 (configuration records held as metadata)",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "typeFacts"
  ],
  "properties": {
    "typeFacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "description": "Owning custom metadata type (__mdt)."
        },
        "record": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "protected": {
          "type": "boolean"
        },
        "fieldsPopulated": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "values": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "field"
            ],
            "properties": {
              "field": {
                "type": "string"
              },
              "value": {
                "type": [
                  "string",
                  "number",
                  "boolean",
                  "null"
                ]
              }
            }
          },
          "description": "Sanitized configuration values as the collector emits them: one {field, value} pair per populated field. Only records the collector deemed safe to commit reach here."
        },
        "references": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "target",
              "assurance"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "pattern": "^[a-z][a-z-]{2,40}$"
              },
              "target": {
                "type": "string",
                "minLength": 1
              },
              "assurance": {
                "enum": [
                  "source-exact",
                  "source-derived-heuristic"
                ]
              }
            }
          }
        }
      }
    },
    "intentionalErrors": {
      "type": "array",
      "maxItems": 0
    }
  }
}
