{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Vescik/sf-harness-brain-core/schemas/test-case-cache.schema.json",
  "title": "Sanitized Azure DevOps test-case cache",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "source", "completeness", "untrustedExternalData", "testCase"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["organization", "project", "testCaseId", "revision", "retrievedAt"],
      "properties": {
        "organization": { "type": "string", "minLength": 1 },
        "project": { "type": "string", "minLength": 1 },
        "testCaseId": { "type": "integer", "minimum": 1 },
        "revision": { "type": "integer", "minimum": 1 },
        "retrievedAt": { "type": "string", "format": "date-time" }
      }
    },
    "completeness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "pagesFetched", "fullStepCoverage", "missingSegments"],
      "properties": {
        "status": { "enum": ["complete", "partial"] },
        "pagesFetched": { "type": "integer", "minimum": 1 },
        "fullStepCoverage": { "type": "boolean" },
        "missingSegments": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "untrustedExternalData": { "const": true },
    "testCase": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "state", "steps", "keywords"],
        "properties": {
          "id": { "type": "integer", "minimum": 1 },
          "title": { "type": "string" },
          "state": { "type": "string" },
          "steps": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["action", "expected"],
              "properties": {
                "action": { "type": "string" },
                "expected": { "type": "string" }
              }
            }
          },
          "keywords": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          }
        }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "completeness": {
            "properties": { "status": { "const": "complete" } },
            "required": ["status"]
          }
        }
      },
      "then": {
        "properties": {
          "completeness": {
            "properties": {
              "fullStepCoverage": { "const": true },
              "missingSegments": { "maxItems": 0 }
            }
          }
        }
      }
    }
  ]
}
