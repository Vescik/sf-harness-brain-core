# ─── Brain-core harness .gitignore ───────────────────────────────────────────
# This repository versions the complete developer workspace: the harness at the
# repository root and the Salesforce DX project under salesforce/.

# ── Raw fetched data ──
# Gitignored by design (blueprint §13 and §17). The folder structure itself stays
# tracked via .gitkeep, so re-include directories and .gitkeep explicitly.
.cache/**
!.cache/**/
!.cache/**/.gitkeep

# ── Generated AI artifacts ──
# output/ holds AI-generated content for human review / manual promotion (docs to the
# wiki, DOCX/PDF export, Playwright scripts moved to tests/ after review) — not curated
# brain. PROVISIONAL: blueprint §13 says output/ git policy "depends on the subfolder"
# and does not resolve which subfolders are committed. Until that is decided, ignore the
# generated CONTENT but keep the folder structure (same pattern as .cache/). Without this,
# the SETUP.md §4 sync ritual (git add -A) would silently commit every generated artifact.
# Revisit per §13 — see BUILD_REPORT.md flag 24.
output/**
!output/**/
!output/**/.gitkeep

# ── OS noise ──
.DS_Store

# ── Salesforce local tooling state ──
# The repository root is the Salesforce DX project. Ignore only local tooling/generated state;
# never ignore force-app/, manifest/, or sfdx-project.json.
/.sfdx/
/.sf/
/.localdevserver/
deploy-options.json
coverage/
.pmdCache
.eslintcache
**/lwc/jsconfig.json
node_modules/
logs/
*.log

# ── Local harness configuration and runtime state ──
config/harness.local.json
# Safety net: only harness.example.json (tracked) and harness.local.json (ignored) are real.
# A stray config/harness.json invites name-confusion and could leak org values if committed.
config/harness.json
.env
.playwright/
*.local.code-workspace
.venv/
__pycache__/
*.pyc
.coverage
htmlcov/
