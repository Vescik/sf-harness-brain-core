{
  "$schema": "../schemas/harness-config.schema.json",
  "schemaVersion": 1,
  "ado": {
    "organization": "<ADO_ORGANIZATION>",
    "project": "<ADO_PROJECT>",
    "releaseQueryId": "<ADO_SAVED_QUERY_ID>",
    "allowedHttpsOrigins": [
      "https://dev.azure.com/<ADO_ORGANIZATION>"
    ]
  },
  "salesforce": {
    "orgs": [
      {
        "alias": "<DEV_ALIAS>",
        "environment": "development",
        "allowAgentRead": true,
        "allowAgentWrite": false
      },
      {
        "alias": "<QA_ALIAS>",
        "environment": "qa",
        "allowAgentRead": true,
        "allowAgentWrite": false
      },
      {
        "alias": "<UAT_ALIAS>",
        "environment": "uat",
        "allowAgentRead": true,
        "allowAgentWrite": false
      }
    ]
  },
  "safety": {
    "sharedSandboxWritesApproved": false,
    "sharedSandboxApprovalRef": ""
  },
  "browser": {
    "allowedOrigins": [
      "https://<MY_DOMAIN>--<SANDBOX>.sandbox.my.salesforce.com"
    ],
    "profileDirectory": "<ABSOLUTE_LOCAL_PROFILE_PATH>"
  },
  "workspace": {
    "salesforceRootName": "salesforce",
    "manifestPath": "manifest/package.xml",
    "promotedTestsPath": "<RELATIVE_PATH_IN_SALESFORCE_ROOT>"
  },
  "cache": {
    "adoItemMaxAgeMinutes": 30,
    "testCaseMaxAgeMinutes": 1440,
    "onStaleDefault": "ask"
  }
}
